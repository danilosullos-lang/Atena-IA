# =============================================================================
# Funções Utilitárias Aprimoradas
# =============================================================================

log() {
    local level="$1"
    shift
    local msg="$*"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    case "$level" in
        ERROR)   echo -e "${RED}❌ ERROR${NC} ${timestamp} - $msg" >&2 ;;
        WARNING) echo -e "${YELLOW}⚠️  WARNING${NC} ${timestamp} - $msg" >&2 ;;
        INFO)    echo -e "${GREEN}✅ INFO${NC}    ${timestamp} - $msg" ;;
        DEBUG)   [[ "$VERBOSE" == true ]] && echo -e "${DIM}🔍 DEBUG${NC}   ${timestamp} - $msg" ;;
        METRIC)  echo -e "${MAGENTA}📊 METRIC${NC} ${timestamp} - $msg" ;;
        HEADER)  echo -e "\n${CYAN}${BOLD}════════════════════════════════════════════════════════════════${NC}"
                 echo -e "${CYAN}${BOLD}  $msg${NC}"
                 echo -e "${CYAN}${BOLD}════════════════════════════════════════════════════════════════${NC}\n" ;;
        *)       echo "$msg" ;;
    esac
    
    # Log para arquivo com rotação automática
    if [[ -d "$LOGS_DIR" ]]; then
        local log_file="$LOGS_DIR/atena_launcher.log"
        
        # Rotaciona log se maior que 100MB
        if [[ -f "$log_file" ]] && [[ $(stat -f%z "$log_file" 2>/dev/null || stat -c%s "$log_file" 2>/dev/null || echo 0) -gt 104857600 ]]; then
            mv "$log_file" "$log_file.old"
            log INFO "Log rotacionado (antigo >100MB)"
        fi
        
        echo "[$timestamp] [$level] $msg" >> "$log_file"
    fi
}

# Detecta tipo de ambiente
detect_environment() {
    log DEBUG "Detectando ambiente..."
    
    if [[ -n "${CI:-}" ]] || [[ -n "${GITHUB_ACTIONS:-}" ]]; then
        ENV_TYPE="ci"
        log INFO "Ambiente detectado: CI/CD (GitHub Actions)"
    elif [[ -n "${DOCKER_ENV:-}" ]] || [[ -f /.dockerenv ]]; then
        ENV_TYPE="container"
        log INFO "Ambiente detectado: Container (Docker)"
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        ENV_TYPE="macos"
        log INFO "Ambiente detectado: macOS"
    elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        ENV_TYPE="linux"
        log INFO "Ambiente detectado: Linux"
    else
        ENV_TYPE="unknown"
        log WARNING "Ambiente não detectado, assumindo Linux"
    fi
    
    # Configurações específicas por ambiente
    case "$ENV_TYPE" in
        ci)
            export PYTHONUNBUFFERED=1
            export ATENA_CI_MODE=true
            LOG_LEVEL="WARNING"
            ;;
        container)
            export PYTHONUNBUFFERED=1
            ;;
    esac
}

# Verifica dependências do sistema
check_system_dependencies() {
    log DEBUG "Verificando dependências do sistema..."
    local missing_deps=()
    
    # Verifica Python
    if ! command -v python3 &> /dev/null; then
        missing_deps+=("python3")
    else
        local py_version=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
        log DEBUG "Python version: $py_version"
        
        # Verifica versão mínima (3.10)
        if [[ "$(echo "$py_version" | cut -d. -f1)" -lt 3 ]] || \
           [[ "$(echo "$py_version" | cut -d. -f1)" -eq 3 && "$(echo "$py_version" | cut -d. -f2)" -lt 10 ]]; then
            log WARNING "Python 3.10+ recomendado, versão atual: $py_version"
        fi
    fi
    
    # Verifica pip
    if ! command -v pip3 &> /dev/null; then
        missing_deps+=("pip3")
    fi
    
    # Verifica git (opcional)
    if ! command -v git &> /dev/null; then
        log WARNING "Git não encontrado (opcional, para auto-atualização)"
    fi
    
    if [[ ${#missing_deps[@]} -gt 0 ]]; then
        log ERROR "Dependências faltando: ${missing_deps[*]}"
        log INFO "Instale com: sudo apt install ${missing_deps[*]} (Ubuntu/Debian)"
        return 1
    fi
    
    return 0
}

# Configura variáveis de ambiente
setup_environment_vars() {
    log DEBUG "Configurando variáveis de ambiente..."
    
    # Protocol Buffers
    export PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python
    
    # Paths
    export ATENA_ROOT="$ROOT_DIR"
    export ATENA_CORE="$CORE_DIR"
    export ATENA_MODULES="$MODULES_DIR"
    export ATENA_EVOLUTION="$EVOLUTION_DIR"
    
    # Configurações de performance
    export ATENA_PARALLEL_WORKERS="${ATENA_PARALLEL_WORKERS:-}"
    export ATENA_CACHE_SIZE="${ATENA_CACHE_SIZE:-1024}"
    
    # Configurações de rede (para CI)
    if [[ "$ENV_TYPE" == "ci" ]]; then
        export ATENA_INTERNET_TIMEOUT="${ATENA_INTERNET_TIMEOUT:-10}"
        export ATENA_MAX_RETRIES="${ATENA_MAX_RETRIES:-2}"
    fi
    
    # Configurações de logging
    export ATENA_LOG_LEVEL="$LOG_LEVEL"
    export ATENA_LOG_DIR="$LOGS_DIR"
    
    # Cria diretórios necessários
    mkdir -p "$EVOLUTION_DIR" "$LOGS_DIR" "$CONFIG_DIR" "$PLUGINS_DIR" "$METRICS_DIR"
}

# Gerenciamento de Virtual Environment
setup_venv() {
    if [[ "$USE_VENV" != true ]]; then
        log DEBUG "Virtual environment desativado"
        return 0
    fi
    
    log INFO "Configurando virtual environment..."
    
    if [[ ! -d "$VENV_DIR" ]]; then
        log INFO "Criando virtual environment em $VENV_DIR"
        python3 -m venv "$VENV_DIR" || error_exit "Falha ao criar virtual environment"
    fi
    
    # Ativa venv
    source "$VENV_DIR/bin/activate" || error_exit "Falha ao ativar virtual environment"
    
    # Atualiza pip
    pip install --upgrade pip --quiet
    
    # Instala dependências se requirements existir
    if [[ -f "$ROOT_DIR/requirements.txt" ]]; then
        log INFO "Instalando dependências do requirements.txt..."
        pip install -r "$ROOT_DIR/requirements.txt" --quiet || log WARNING "Falha ao instalar algumas dependências"
    fi
    
    # Define comando Python
    PYTHON_CMD="python"
    log INFO "Virtual environment ativado com sucesso"
}

# Auto-scaling baseado em recursos disponíveis
auto_scale_resources() {
    if [[ "$AUTO_SCALE" != true ]]; then
        return 0
    fi
    
    log INFO "Executando auto-scaling baseado em recursos..."
    
    # Detecta número de CPUs
    local cpu_count=$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo "1")
    local mem_total=$(free -m | awk '/^Mem:/{print $2}' 2>/dev/null || echo "1024")
    
    # Calcula workers baseado em CPU e memória
    local recommended_workers=$((cpu_count / 2))
    [[ $recommended_workers -lt 1 ]] && recommended_workers=1
    [[ $recommended_workers -gt 8 ]] && recommended_workers=8
    
    # Memória: cada worker consome ~500MB
    local max_workers_by_mem=$((mem_total / 500))
    [[ $max_workers_by_mem -lt 1 ]] && max_workers_by_mem=1
    
    local final_workers=$recommended_workers
    [[ $final_workers -gt $max_workers_by_mem ]] && final_workers=$max_workers_by_mem
    
    export ATENA_PARALLEL_WORKERS="${ATENA_PARALLEL_WORKERS:-$final_workers}"
    
    # Cache size baseado em memória disponível
    local cache_size_mb=$((mem_total / 4))
    export ATENA_CACHE_SIZE_MB="${ATENA_CACHE_SIZE_MB:-$cache_size_mb}"
    
    log INFO "Auto-scaling configurado: Workers=$final_workers, Cache=${cache_size_mb}MB"
    log INFO "Recursos disponíveis: CPUs=$cpu_count, Memória Total=${mem_total}MB"
}

# Configurações de performance
optimize_performance() {
    log DEBUG "Otimizando performance..."
    
    # PyPy detection (faster for some workloads)
    if python3 -c "import sys; sys.exit(0 if 'pypy' in sys.version.lower() else 1)" 2>/dev/null; then
        log INFO "PyPy detectado - performance otimizada para workloads Python puro"
    fi
    
    # NUMA binding (se disponível)
    if command -v numactl &> /dev/null; then
        local node_count=$(numactl --hardware 2>/dev/null | grep "available:" | awk '{print $2}' || echo "1")
        if [[ "$node_count" -gt 1 ]]; then
            log DEBUG "Sistema NUMA com $node_count nós detectado"
            export ATENA_NUMA_NODE=0
        fi
    fi
    
    # Limites de sistema
    local max_open_files=$(ulimit -n)
    if [[ "$max_open_files" -lt 4096 ]]; then
        log DEBUG "Aumentando limite de arquivos abertos (atual: $max_open_files)"
        ulimit -n 4096 2>/dev/null || log WARNING "Não foi possível aumentar limite de arquivos"
    fi
}

# Auto-recuperação de falhas
setup_recovery() {
    # Cria arquivo de lock para evitar execuções concorrentes
    local current_user="${USER:-$(id -un 2>/dev/null || echo unknown)}"
    ATENA_LOCK_FILE="/tmp/atena_${current_user}.lock"
    
    if [[ -f "$ATENA_LOCK_FILE" ]]; then
        local pid=$(cat "$ATENA_LOCK_FILE" 2>/dev/null || echo "")
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            log WARNING "ATENA já está em execução (PID: $pid)"
            if [[ "${ATENA_FORCE:-false}" != "true" ]]; then
                error_exit "Use ATENA_FORCE=true para forçar execução" 0
            fi
            log WARNING "Forçando execução..."
        fi
    fi
    
    echo $$ > "$ATENA_LOCK_FILE"
    
    # Cleanup on exit
    trap 'rm -f "${ATENA_LOCK_FILE:-}"' EXIT INT TERM
}

# Auto-setup de dependências de endpoint para automação de computador
auto_setup_endpoint_readiness() {
    local auto_flag="${ATENA_AUTO_ENDPOINT_SETUP:-true}"
    if [[ "$auto_flag" != "true" ]]; then
        log INFO "Auto-setup de endpoint desativado (ATENA_AUTO_ENDPOINT_SETUP=false)."
        return 0
    fi
    local installer="$ROOT_DIR/setup/install_endpoint_readiness.sh"
    if [[ ! -x "$installer" ]]; then
        log DEBUG "Instalador de endpoint não encontrado: $installer"
        return 0
    fi
    log INFO "Verificando prontidão de endpoint para mouse/teclado/OCR..."
    if "$installer" --check >/dev/null 2>&1; then
        log INFO "Endpoint já está pronto."
        return 0
    fi
    log WARNING "Endpoint não pronto. Executando instalação automática de dependências..."
    "$installer" --apply || log WARNING "Instalação automática parcial/sem permissões completas."
}

# Gate de prontidão: impede iniciar atuadores de endpoint sem requisitos mínimos.
enforce_endpoint_readiness_gate() {
    local require_gate="${ATENA_REQUIRE_READY:-false}"
    local allow_degraded="${ATENA_ALLOW_DEGRADED:-false}"
    if [[ "$require_gate" != "true" ]]; then
        return 0
    fi
    local audit_script="$ROOT_DIR/scripts/audit_agent_endpoint_readiness.sh"
    if [[ ! -x "$audit_script" ]]; then
        log WARNING "Gate solicitado, mas script de auditoria não encontrado."
        return 0
    fi
    log INFO "Executando gate de prontidão de endpoint..."
    if "$audit_script"; then
        log INFO "Gate de endpoint aprovado."
        return 0
    fi
    if [[ "$allow_degraded" == "true" ]]; then
        log WARNING "Gate falhou, mas ATENA_ALLOW_DEGRADED=true. Continuando em modo degradado."
        return 0
    fi
    error_exit "Endpoint não está pronto para automação (gate bloqueou inicialização)." 1
}

# Coleta métricas do sistema
collect_metrics() {
    local metrics_file="$METRICS_DIR/metrics_$(date +%Y%m%d).json"
    mkdir -p "$METRICS_DIR"
    
    # Coleta métricas básicas
    local cpu_usage=$(top -bn1 | grep "Cpu(s)" | awk '{print $2}' | cut -d'%' -f1 2>/dev/null || echo "0")
    local mem_usage=$(free | grep Mem | awk '{print ($3/$2) * 100.0}' 2>/dev/null || echo "0")
    local disk_usage=$(df -h "$ROOT_DIR" | tail -1 | awk '{print $5}' | tr -d '%' 2>/dev/null || echo "0")
    local load_avg=$(uptime | awk -F'load average:' '{print $2}' | cut -d, -f1 2>/dev/null || echo "0")
    
    # Métricas de processo (se ATENA estiver rodando)
    local atena_pid=$(pgrep -f "atena_terminal_assistant.py" | head -1 || echo "")
    local atena_cpu="0"
    local atena_mem="0"
    
    if [[ -n "$atena_pid" ]]; then
        atena_cpu=$(ps -p "$atena_pid" -o %cpu= 2>/dev/null | tr -d ' ' || echo "0")
        atena_mem=$(ps -p "$atena_pid" -o %mem= 2>/dev/null | tr -d ' ' || echo "0")
    fi
    
    # Salva métricas em JSON
    cat > "$metrics_file" << EOF
{
    "timestamp": "$(date -Iseconds)",
    "version": "$ATENA_VERSION",
    "environment": "$ENV_TYPE",
    "system": {
        "cpu_percent": $cpu_usage,
        "memory_percent": $mem_usage,
        "disk_percent": $disk_usage,
        "load_average": $load_avg
    },
    "atena": {
        "pid": "$atena_pid",
        "cpu_percent": $atena_cpu,
        "memory_percent": $atena_mem
    }
}
EOF
    
    log METRIC "Métricas coletadas: CPU=${cpu_usage}% MEM=${mem_usage}% DISK=${disk_usage}%"
    
    if [[ "$COLLECT_METRICS" == true ]]; then
        # Exibe métricas formatadas
        echo -e "\n${BOLD}📊 Métricas do Sistema:${NC}"
        echo "  CPU Usage:    ${cpu_usage}%"
        echo "  Memory Usage: ${mem_usage}%"
        echo "  Disk Usage:   ${disk_usage}%"
        echo "  Load Average: ${load_avg}"
        
        if [[ -n "$atena_pid" ]]; then
            echo "  ATENA PID:    $atena_pid"
            echo "  ATENA CPU:    ${atena_cpu}%"
            echo "  ATENA MEM:    ${atena_mem}%"
        fi
    fi
}

# Rotação automática de logs antigos
rotate_old_logs() {
    local retention_days="${ATENA_LOG_RETENTION_DAYS:-30}"
    log DEBUG "Removendo logs com mais de $retention_days dias..."
    
    find "$LOGS_DIR" -name "*.log" -type f -mtime "+$retention_days" -delete 2>/dev/null || true
    find "$LOGS_DIR" -name "*.log.old" -type f -mtime "+$retention_days" -delete 2>/dev/null || true
}

# Monitoramento de recursos em tempo real
start_monitoring() {
    local monitor_pid=$1
    local monitor_log="$LOGS_DIR/atena_monitor_$$.log"
    
    log DEBUG "Iniciando monitoramento de recursos (PID: $monitor_pid)"
    
    # Loop de monitoramento em background
    (
        while kill -0 "$monitor_pid" 2>/dev/null; do
            local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
            local cpu=0
            local mem=0
            
            if [[ "$OSTYPE" == "linux-gnu"* ]]; then
                # Linux: usa /proc
                if [[ -f "/proc/$monitor_pid/stat" ]]; then
                    local stat=$(cat "/proc/$monitor_pid/stat" 2>/dev/null || echo "")
                    cpu=$(echo "$stat" | awk '{print int($14+$15)/100}' 2>/dev/null || echo "0")
                fi
                if [[ -f "/proc/$monitor_pid/status" ]]; then
                    mem=$(grep -i "VmRSS" "/proc/$monitor_pid/status" 2>/dev/null | awk '{print int($2/1024)}' || echo "0")
                fi
            elif [[ "$OSTYPE" == "darwin"* ]]; then
                # macOS: usa ps
                cpu=$(ps -o "%cpu" -p "$monitor_pid" 2>/dev/null | tail -1 | awk '{print int($1)}' || echo "0")
                mem=$(ps -o "rss" -p "$monitor_pid" 2>/dev/null | tail -1 | awk '{print int($1/1024)}' || echo "0")
            fi
            
            echo "[$timestamp] CPU: ${cpu}% | MEM: ${mem}MB" >> "$monitor_log"
            sleep 5
        done
        
        echo "Monitoramento finalizado em $(date)" >> "$monitor_log"
    ) &
    
    local monitor_thread=$!
    log DEBUG "Monitor thread iniciado (PID: $monitor_thread)"
    
    # Salva PID do monitor para cleanup
    echo "$monitor_thread" > "$LOGS_DIR/monitor_$$.pid"
}

# Modo doctor - diagnóstico do sistema
run_doctor() {
    log HEADER "🔧 ATENA Doctor - Diagnóstico do Sistema"
    
    echo -e "${BOLD}Informações do Sistema:${NC}"
    echo "  OS: $(uname -a)"
    echo "  Shell: $SHELL"
    echo "  Usuário: ${USER:-$(id -un 2>/dev/null || echo unknown)}"
    echo "  Diretório: $ROOT_DIR"
    echo ""
    
    echo -e "${BOLD}Python:${NC}"
    python3 --version 2>&1 || echo "  ❌ Python não encontrado"
    echo "  PIP: $(pip3 --version 2>&1 | head -1 || echo '❌')"
    echo ""
    
    echo -e "${BOLD}Dependências:${NC}"
    local missing=()
    for dep in python3 pip3 git; do
        if command -v "$dep" &> /dev/null; then
            echo "  ✅ $dep"
        else
            echo "  ❌ $dep"
            missing+=("$dep")
        fi
    done
    
    echo ""
    echo -e "${BOLD}Diretórios:${NC}"
    for dir in "$CORE_DIR" "$MODULES_DIR" "$EVOLUTION_DIR"; do
        if [[ -d "$dir" ]]; then
            local count=$(find "$dir" -type f -name "*.py" 2>/dev/null | wc -l)
            echo "  ✅ $dir ($count arquivos .py)"
        else
            echo "  ⚠️  $dir (não existe)"
        fi
    done
    
    echo ""
    echo -e "${BOLD}Ambiente:${NC}"
    echo "  ATENA_ROOT: ${ATENA_ROOT:-não definido}"
    echo "  PYTHONPATH: ${PYTHONPATH:-não definido}"
    echo "  VIRTUAL_ENV: ${VIRTUAL_ENV:-não ativado}"
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo ""
        echo -e "${YELLOW}⚠️  Dependências faltando: ${missing[*]}${NC}"
        return 1
    fi
    
    echo ""
    echo -e "${GREEN}✅ Sistema saudável!${NC}"
    return 0
}

# Auto-atualização via git
run_update() {
    log HEADER "🔄 ATENA Auto-Atualização"
    
    if ! command -v git &> /dev/null; then
        error_exit "Git não encontrado. Instale git para auto-atualização."
    fi
    
    if [[ ! -d "$ROOT_DIR/.git" ]]; then
        error_exit "Não é um repositório git. Clone o repositório para auto-atualização."
    fi
    
    log INFO "Buscando atualizações..."
    git fetch origin --quiet
    
    local local_hash=$(git rev-parse HEAD)
    local remote_hash=$(git rev-parse origin/main 2>/dev/null || git rev-parse origin/master 2>/dev/null || echo "")
    
    if [[ -z "$remote_hash" ]]; then
        log WARNING "Não foi possível determinar branch remoto"
        return 1
    fi
    
    if [[ "$local_hash" == "$remote_hash" ]]; then
        log INFO "ATENA já está atualizada (${local_hash:0:8})"
        return 0
    fi
    
    log INFO "Atualização disponível: ${local_hash:0:8} → ${remote_hash:0:8}"
    
    # Backup antes de atualizar
    local backup_dir="$EVOLUTION_DIR/backup_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$backup_dir"
    cp -r "$CORE_DIR" "$backup_dir/" 2>/dev/null || true
    cp -r "$MODULES_DIR" "$backup_dir/" 2>/dev/null || true
    log INFO "Backup salvo em: $backup_dir"
    
    # Pull das mudanças
    git pull --quiet || error_exit "Falha ao atualizar repositório"
    
    # Recria venv se necessário
    if [[ -d "$VENV_DIR" ]]; then
        log INFO "Atualizando dependências..."
        source "$VENV_DIR/bin/activate"
        if [[ -f "$ROOT_DIR/requirements.txt" ]]; then
            pip install --upgrade -r "$ROOT_DIR/requirements.txt" --quiet || log WARNING "Falha ao atualizar dependências"
        fi
    fi
    
    log INFO "✅ ATENA atualizada com sucesso!"
    log INFO "Reinicie a ATENA para aplicar as mudanças"
    return 0
}

# Mostra ajuda completa
show_help() {
    cat << EOF
${CYAN}${BOLD}🔱 $ATENA_NAME Launcher v$ATENA_VERSION${NC}

${BOLD}Uso:${NC}
    $0 [OPÇÕES] [COMANDO]

${BOLD}Opções:${NC}
    --help, -h          Mostra esta ajuda
    --version, -v       Mostra versão
    --verbose, -V       Modo verboso (debug)
    --no-color          Desativa cores no output
    --venv              Usa virtual environment
    --auto              Modo autônomo (executa e sai)
    --doctor            Executa diagnóstico do sistema
    --update            Auto-atualização via git
    --metrics           Exibe métricas de performance
    --scale             Auto-scale baseado em recursos
    --monitor           Modo monitor com métricas em tempo real
    --perf-diag         Diagnóstico detalhado de performance

${BOLD}Comandos:${NC}
    (nenhum)            Modo interativo padrão
    assistant           Modo assistente de terminal
    manus               Alias do assistente (modo Manus)
    codex               Alias do assistente (modo Codex)
    claude-code         Alias do assistente (modo Claude Code)
    benchmark           Executa benchmark completo
    self-test           Auto-validação da ATENA
    release-gate        Avalia readiness para release
    install-deps        Planeja/instala dependências (use --apply para executar)
    github-scan         Vasculha GitHub para evolução da ATENA
    future-ai-fabric    Cria blueprint de tecnologia futura de IA

${BOLD}Variáveis de Ambiente:${NC}
    ATENA_FORCE         Força execução mesmo com lock
    ATENA_CI_MODE       Modo CI (logs reduzidos)
    ATENA_PARALLEL_WORKERS  Número de workers paralelos
    ATENA_LOG_LEVEL     DEBUG|INFO|WARNING|ERROR
    ATENA_AUTO_ENDPOINT_SETUP  Auto-configura dependências de automação (true/false)

${BOLD}Exemplos:${NC}
    $0                           # Inicia modo interativo com banner
    $0 --auto                    # Modo autônomo (CI/CD)
    $0 --doctor                  # Diagnóstico completo
    $0 --venv assistant          # Modo assistente com venv
    $0 --metrics                 # Exibe métricas do sistema
    $0 --scale --monitor         # Inicia com auto-scale e monitoramento
    $0 install-deps --apply      # Instala dependências da ATENA
    $0 github-scan ai agents     # Busca sinais no GitHub para evolução
    $0 --update                  # Auto-atualização

${DIM}Documentação: https://github.com/AtenaAuto/ATENA-${NC}
EOF
}

# Mostra versão
show_version() {
    echo "${ATENA_NAME} v${ATENA_VERSION}"
    echo "Python: $(python3 --version 2>&1)"
    if [[ -d "$ROOT_DIR/.git" ]]; then
        local git_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
        echo "Git: $git_hash"
    fi
}

# =============================================================================
# Main
# =============================================================================

main() {
    local mode=""
    local args=()
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                show_help
                exit 0
                ;;
            --version|-v)
                show_version
                exit 0
                ;;
            --verbose|-V)
                VERBOSE=true
                LOG_LEVEL="DEBUG"
                shift
                ;;
            --no-color)
                NO_COLOR=true
                shift
                ;;
            --venv)
                USE_VENV=true
                shift
                ;;
            --auto)
                mode="auto"
                shift
                ;;
            --doctor)
                mode="doctor"
                shift
                ;;
            --update)
                mode="update"
                shift
                ;;
            --benchmark)
                mode="benchmark"
                shift
                ;;
            --self-test)
                mode="self-test"
                shift
                ;;
            --release-gate)
                mode="release-gate"
                shift
                ;;
            --install-deps)
                mode="install-deps"
                shift
                ;;
            --metrics)
                mode="metrics"
                shift
                ;;
            --scale)
                AUTO_SCALE=true
                shift
                ;;
            --monitor)
                mode="monitor"
                shift
                ;;
            --perf-diag)
                mode="perf_diag"
                shift
                ;;
            assistant|manus|codex|claude-code|benchmark|self-test|release-gate|install-deps|github-scan|future-ai-fabric|production-center)
                mode="$1"
                shift
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done
    
    # Modos que não mostram banner completo
    case "$mode" in
        doctor|update|metrics|perf_diag|install-deps)
            SHOW_STATUS=false
            ;;
        *)
            SHOW_STATUS=true
            ;;
    esac
    
    # Modo produção center (JSON output) - não mostra banner
    if [[ "$mode" == "production-center" ]]; then
        if [[ -x "$VENV_DIR/bin/python" ]]; then
            PYTHON_CMD="$VENV_DIR/bin/python"
        fi
        exec "$PYTHON_CMD" "$CORE_DIR/atena_production_center.py" "${args[@]}"
    fi    
    # Modo métricas (rápido, sem setup completo)
    if [[ "$mode" == "metrics" ]]; then
        collect_metrics
        exit 0
    fi
    
    # Modo diagnóstico de performance
    if [[ "$mode" == "perf_diag" ]]; then
        performance_diagnostic
        exit 0
    fi
    
    # Modos especiais (não precisam do ambiente completo)
    case "$mode" in
        doctor)
            detect_environment
            check_system_dependencies
            run_doctor
            exit $?
            ;;
        update)
            detect_environment
            run_update
            exit $?
            ;;
    esac
    
    # Setup completo
    detect_environment
    check_system_dependencies || error_exit "Dependências do sistema não satisfeitas" 1
    setup_environment_vars
    setup_venv
    auto_scale_resources
    optimize_performance
    setup_recovery
    rotate_old_logs
    
    # Mostra banner (se não for modo especial)
    if [[ "$mode" != "install-deps" ]] && [[ "$mode" != "github-scan" ]] && [[ "$mode" != "future-ai-fabric" ]]; then
        show_banner
    fi
    
    # Comandos específicos
    case "$mode" in
        auto)
            log INFO "Modo autônomo ativado"
            export ATENA_AUTO_MODE=true
            exec $PYTHON_CMD "$CORE_DIR/atena_launcher.py" start "${args[@]}"
            ;;
        benchmark)
            log INFO "Executando benchmark..."
            exec $PYTHON_CMD "$CORE_DIR/atena_benchmark.py" "${args[@]}"
            ;;
        self-test)
            log INFO "Executando self-test..."
            exec $PYTHON_CMD "$CORE_DIR/atena_self_test.py" "${args[@]}"
            ;;
        release-gate)
            log INFO "Executando release gate..."
            exec $PYTHON_CMD "$CORE_DIR/atena_release_gate.py" "${args[@]}"
            ;;
        install-deps)
            log INFO "Planejando/instalando dependências..."
            exec $PYTHON_CMD "$CORE_DIR/atena_dependency_installer.py" "${args[@]}"
            ;;
        github-scan)
            log INFO "Vasculhando GitHub para evolução..."
            exec $PYTHON_CMD "$CORE_DIR/atena_github_evolution_scan.py" "${args[@]}"
            ;;
        future-ai-fabric)
            log INFO "Criando tecnologia futura de IA..."
            exec $PYTHON_CMD "$CORE_DIR/atena_neurocausal_memory_fabric.py" "${args[@]}"
            ;;
        monitor)
            log INFO "Iniciando com monitoramento..."
            COLLECT_METRICS=true
            $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}" &
            local atena_pid=$!
            start_monitoring "$atena_pid"
            
            # Coleta métricas periodicamente
            (
                while kill -0 "$atena_pid" 2>/dev/null; do
                    collect_metrics >/dev/null 2>&1
                    sleep 60
                done
            ) &
            
            wait "$atena_pid"
            ;;
        assistant|manus|codex|claude-code)
            log INFO "Iniciando assistente de terminal..."
            auto_setup_endpoint_readiness
            enforce_endpoint_readiness_gate
            exec $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}"
            ;;
        production-center)
            exec $PYTHON_CMD "$CORE_DIR/atena_production_center.py" "${args[@]}"
            ;;
        *)
            # Modo padrão - interativo
            log INFO "Iniciando $ATENA_NAME em modo interativo..."
            auto_setup_endpoint_readiness
            enforce_endpoint_readiness_gate
            exec $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}"
            ;;
    esac
}

# =============================================================================
# Funções de Diagnóstico de Performance
# =============================================================================

performance_diagnostic() {
    log HEADER "🔍 Diagnóstico de Performance"
    
    echo -e "${BOLD}CPU:${NC}"
    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
        lscpu | grep -E "Model name|Socket|Core|Thread|CPU MHz" || echo "  Informações não disponíveis"
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        sysctl -n machdep.cpu.brand_string
        echo "  Cores: $(sysctl -n hw.ncpu)"
    fi
    
    echo -e "\n${BOLD}Memória:${NC}"
    free -h 2>/dev/null || vm_stat 2>/dev/null || echo "  Informações não disponíveis"
    
    echo -e "\n${BOLD}Disco:${NC}"
    df -h "$ROOT_DIR"
    
    echo -e "\n${BOLD}Rede:${NC}"
    if command -v ifconfig &> /dev/null; then
        ifconfig | grep -E "eth|wlan|en" -A1 | grep "inet " || echo "  Informações de rede não disponíveis"
    fi
    
    echo -e "\n${BOLD}Python Performance:${NC}"
    $PYTHON_CMD -c "import sys; print(f'  Python: {sys.version}')"
    $PYTHON_CMD -c "import timeit; print(f'  Loop performance: {timeit.timeit(\"pass\", number=1000000):.2f} ops/ms')" 2>/dev/null || echo "  Não disponível"
}

# Executa main
main "$@"
